<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="week6.TestController">

    <children>
        <BorderPane prefHeight="500.0" prefWidth="850.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- Top -->
            <top>
                <VBox>
                    <children>

                        <MenuBar fx:id="menubar" prefHeight="38.0" prefWidth="850.0" styleClass="top-menu-bar">
                            <menus>

                                <Menu styleClass="menu-title" text="File">
                                    <items>
                                        <MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" />
                                    </items>
                                </Menu>

                                <Menu styleClass="menu-title" text="Appearance">
                                    <items>

                                        <Menu text="Font Size">
                                            <items>
                                                
                                                <RadioMenuItem text="Small">
                                       <toggleGroup>
                                          <ToggleGroup fx:id="tg" />
                                       </toggleGroup></RadioMenuItem>
                                                <RadioMenuItem selected="true" text="Medium" toggleGroup="$tg" />
                                                <RadioMenuItem text="Large" toggleGroup="$tg" />
                                            </items>
                                        </Menu>

                                        <Menu text="Font Family">
                                            <items>
                                                
                                                <RadioMenuItem selected="true" text="Arial">
                                       <toggleGroup>
                                          <ToggleGroup fx:id="tg2" />
                                       </toggleGroup></RadioMenuItem>
                                                <RadioMenuItem text="Times New Roman" toggleGroup="$tg2" />
                                                <RadioMenuItem text="Sans Serif" toggleGroup="$tg2" />
                                            </items>
                                        </Menu>
                              <Menu text="Font Style">
                                 <items>
                                    <CheckMenuItem mnemonicParsing="false" text="Bold" />
                                    <CheckMenuItem mnemonicParsing="false" text="italic" />
                                 </items>
                              </Menu>

                                    </items>
                                </Menu>

                                <Menu styleClass="menu-title" text="Help">
                                    <items>
                                        <MenuItem fx:id="about" onAction="#aboutHandle" text="About" />
                                    </items>
                                </Menu>

                            </menus>
                        </MenuBar>

                        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-bar">
                            <children>
                                <Label styleClass="header-title" text="Employee Performance Dashboard" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label styleClass="header-user" text="HR Manager" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                            </padding>
                        </HBox>

                    </children>
                </VBox>
            </top>

            <!-- Center -->
            <center>
                <HBox prefHeight="414.0" prefWidth="615.0" spacing="20" styleClass="main-content">
                    <children>

                        <!-- Right Part: HR Rating -->
                        <VBox maxHeight="370.0" minHeight="370.0" prefHeight="370.0" spacing="15" styleClass="right-panel" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="section-title" text="HR Review" />
                                <Separator />

                                <Label text="Review Date" />
                                <DatePicker fx:id="datePicker" prefWidth="200.0" />
                                <HBox alignment="CENTER_LEFT" spacing="10" />

                                <Label text="Comment" />
                                <TextArea fx:id="textArea" maxHeight="70.0" minHeight="70.0" onMouseDragged="#sliderHandle" prefHeight="70.0" promptText="Write HR comment here or load it from a file..." style="-fx-font-size: 25;" wrapText="true" />
                        <Slider fx:id="slider" blockIncrement="0.0" majorTickUnit="5.0" max="50.0" min="10.0" minorTickCount="0" onMouseDragged="#sliderHandle" showTickLabels="true" showTickMarks="true" value="10.0" />

                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <children>
                                        <Button fx:id="upload" lineSpacing="1.0" onAction="#uploadHandle" text="Upload Comment File" />
                              <Button fx:id="save" onAction="#saveHandle" text="Save" />
                                    </children>
                                </HBox>
                            </children>

                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>

                        <!-- Left Part: Employee Profile -->
                        <VBox alignment="TOP_CENTER" minWidth="250.0" spacing="15" styleClass="left-panel">
                            <children>
                                <Label styleClass="section-title" text="Employee Profile" />
                                <Separator prefWidth="180.0" />

                                <StackPane styleClass="image-frame">
                                    <children>
                                        <ImageView fx:id="imgView" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
                                    </children>
                                </StackPane>

                                <Label fx:id="nameLabel" lineSpacing="1.0" styleClass="employee-name" text="Sami" />
                                <Label fx:id="departmentLabel" styleClass="employee-department" text="IT Department" />
                            </children>

                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>

                    </children>

                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </HBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>
